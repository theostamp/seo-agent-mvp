APP_NAME=seo-agent-mvp
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/seo_agent

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
LLM_PROVIDER=gemini

WORDPRESS_BASE_URL=https://oikonrg.gr
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WORDPRESS_TIMEOUT=30
WORDPRESS_PER_PAGE=100
WORDPRESS_MAX_PAGES=20
WORDPRESS_CACHE_TTL_SECONDS=300

GENERATED_CONTENT_DIR=generated_content

DEFAULT_LANGUAGE=el
DEFAULT_COUNTRY=GR
DEFAULT_CITY=Athens
